{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "SbtDeskTool",
  "version": "1.26.7-21.40",
  "identifier": "com.sabitech.sbtdesktool",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "SbtDeskTool",
        "width": 420,
        "height": 260,
        "minWidth": 340,
        "minHeight": 120,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "dragDropEnabled": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "macOS": {
      "signingIdentity": "-"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEREOUNCMUMyQjRDNkQ2MTIKUldRUzFzYTB3ckdjM1liYVpYdGJiQVpZREhoUmNKN3NTSmhBbG90cjFNbGVwc2t3ZVJCU0ExK0oK",
      "endpoints": [
        "https://github.com/SabiTechHolding/SbtDeskTool/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "quiet"
      }
    }
  }
}
